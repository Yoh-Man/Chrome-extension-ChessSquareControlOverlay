{
  "manifest_version": 3,
  "name": "Chess Square Control Overlay",
  "version": "2.0",
  "description": "Visualize which squares are controlled by White and Black on chess.com",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
